{
  "name": "deepsteve",
  "version": "0.20.4",
  "private": true,
  "description": "Web UI for running multiple Claude Code and Codex beta instances in browser tabs",
  "license": "MIT",
  "author": "Fncore, Inc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deepsteve/deepsteve.git"
  },
  "main": "server.js",
  "scripts": {
    "test": "sh test/run-integration.sh",
    "test:unit": "node --test test/unit/*.test.js",
    "test:standalone": "sh test/run-standalone.sh",
    "test:docker": "docker compose -f test/docker-compose.yml up --build --abort-on-container-exit --exit-code-from test",
    "test:docker:clean": "docker compose -f test/docker-compose.yml down -v --rmi local",
    "test:install": "bash release.sh && docker compose -f test/docker-compose.install.yml up --build --abort-on-container-exit --exit-code-from test",
    "test:install:clean": "docker compose -f test/docker-compose.install.yml down -v --rmi local",
    "test:docker:public": "docker compose -f test/docker-compose.public.yml up --build --abort-on-container-exit --exit-code-from test",
    "test:docker:public:clean": "docker compose -f test/docker-compose.public.yml down -v --rmi local"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.22.2",
    "node-pty": "^1.0.0",
    "selfsigned": "^5.0.0",
    "ws": "^8.20.1",
    "facebook-nodejs-business-sdk": "^20.0.0",
    "zod": "^3.24.0"
  }
}
