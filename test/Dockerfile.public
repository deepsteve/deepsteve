# Installs from the published install.sh at deepsteve.com.
# Tests that the live public install script produces a working server.
# See also: Dockerfile (repo source), Dockerfile.install (local install.sh).
FROM node:22-bookworm

# zsh: server.js spawns 'zsh -l' for all session types
# curl: used by docker-compose healthcheck + public install
RUN apt-get update && apt-get install -y --no-install-recommends zsh curl && rm -rf /var/lib/apt/lists/*

# Stub out launchctl/systemctl — not available in Docker
RUN printf '#!/bin/sh\nexit 0\n' > /usr/local/bin/launchctl && chmod +x /usr/local/bin/launchctl \
 && printf '#!/bin/sh\nexit 0\n' > /usr/local/bin/systemctl && chmod +x /usr/local/bin/systemctl \
 && curl -fsSL deepsteve.com/install.sh | bash

WORKDIR /root/.deepsteve

EXPOSE 3000

CMD ["node", "server.js"]
