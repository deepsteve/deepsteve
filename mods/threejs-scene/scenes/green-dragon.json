    { "op": "eval", "code": "const dragon=registry.get('dragon').object3d,neckGroup=registry.get('neckGroup').object3d,headGroup=registry.get('headGroup').object3d,jawGroup=registry.get('jawGroup').object3d,wingL=registry.get('wingL').object3d,wingR=registry.get('wingR').object3d,tail0=registry.get('tail0').object3d,tail1=registry.get('tail1').object3d,tail2=registry.get('tail2').object3d,tail3=registry.get('tail3').object3d,tail4=registry.get('tail4').object3d,fireLight=registry.get('fireLight').object3d;const fireCount=120,fireGeo=new THREE.BufferGeometry(),firePos=new Float32Array(fireCount*3),fireVel=new Float32Array(fireCount*3),fireLife=new Float32Array(fireCount),fireAge=new Float32Array(fireCount);for(let i=0;i<fireCount;i++){fireLife[i]=.4+Math.random()*.5;fireAge[i]=Math.random()*fireLife[i];firePos[i*3]=(Math.random()-.5)*.15;firePos[i*3+1]=(Math.random()-.5)*.1;firePos[i*3+2]=Math.random()*.3;fireVel[i*3]=(Math.random()-.5)*.4;fireVel[i*3+1]=.5+Math.random()*.8;fireVel[i*3+2]=1.5+Math.random()*1.5}fireGeo.setAttribute('position',new THREE.BufferAttribute(firePos,3));const fireMat=new THREE.ShaderMaterial({vertexShader:'void main(){vec4 mv=modelViewMatrix*vec4(position,1.0);gl_PointSize=180.0/-mv.z;gl_Position=projectionMatrix*mv;}',fragmentShader:'void main(){float d=length(gl_PointCoord-vec2(0.5));if(d>0.5)discard;float a=1.0-smoothstep(0.0,0.5,d);vec3 c=mix(vec3(1.0,0.2,0.0),vec3(1.0,0.9,0.0),d*2.0);gl_FragColor=vec4(c,a*0.7);}',transparent:true,depthWrite:false,blending:THREE.AdditiveBlending});const firePoints=new THREE.Points(fireGeo,fireMat);firePoints.visible=false;headGroup.add(firePoints);firePoints.position.set(0,.05,1.2);let breathTimer=0,isBreathing=false,breathDuration=0;onFrame('dragon-anim',function(dt,t){dragon.position.y=Math.sin(t*.8)*.03;neckGroup.rotation.x=Math.sin(t*.5)*.04;neckGroup.rotation.y=Math.sin(t*.3)*.03;headGroup.rotation.x=Math.sin(t*.7+1)*.03;headGroup.rotation.y=Math.sin(t*.4+2)*.025;const wingCycle=t%12;let wingAngle=0;if(wingCycle>9&&wingCycle<11){wingAngle=Math.sin((wingCycle-9)*Math.PI*3)*.35}else{wingAngle=Math.sin(t*.6)*.03}wingL.rotation.z=-.6+wingAngle;wingR.rotation.z=.6-wingAngle;const ts=.6;tail0.rotation.y=Math.sin(t*ts)*.08;tail1.rotation.y=Math.sin(t*ts-.4)*.12;tail2.rotation.y=Math.sin(t*ts-.8)*.18;tail3.rotation.y=Math.sin(t*ts-1.2)*.25;tail4.rotation.y=Math.sin(t*ts-1.6)*.3;const w=t%8;if(w>5.5&&w<7.5){const i=Math.sin((w-5.5)/2*Math.PI);dragon.rotation.y=Math.sin(t*2)*.06*i;dragon.rotation.z=Math.sin(t*1.5+1)*.03*i}else{dragon.rotation.y*=.95;dragon.rotation.z*=.95}breathTimer+=dt;if(!isBreathing&&breathTimer>8+Math.random()*4){isBreathing=true;breathDuration=0;breathTimer=0;firePoints.visible=true}if(isBreathing){breathDuration+=dt;jawGroup.rotation.x=Math.min(breathDuration*3,.3);for(let i=0;i<fireCount;i++){fireAge[i]+=dt;if(fireAge[i]>=fireLife[i]){fireAge[i]=0;fireLife[i]=.3+Math.random()*.4;firePos[i*3]=(Math.random()-.5)*.15;firePos[i*3+1]=(Math.random()-.5)*.1;firePos[i*3+2]=Math.random()*.2;fireVel[i*3]=(Math.random()-.5)*.5;fireVel[i*3+1]=.3+Math.random()*.6;fireVel[i*3+2]=2+Math.random()*2}firePos[i*3]+=fireVel[i*3]*dt;firePos[i*3+1]+=fireVel[i*3+1]*dt;firePos[i*3+2]+=fireVel[i*3+2]*dt}fireGeo.attributes.position.needsUpdate=true;fireLight.intensity=2.5+Math.sin(t*15);if(breathDuration>2.5){isBreathing=false;firePoints.visible=false;fireLight.intensity=0;jawGroup.rotation.x=0}}else{jawGroup.rotation.x=Math.sin(t*.9)*.02;fireLight.intensity*=.9}})" }
  ]
}
